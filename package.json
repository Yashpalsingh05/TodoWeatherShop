{
  "name": "todo-weather-ecommerce-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "bash -c 'source ~/.nvm/nvm.sh && nvm use 18 && DATABASE_URL=\"file:./dev.db\" npx prisma generate && DATABASE_URL=\"file:./dev.db\" npx prisma db push && DATABASE_URL=\"file:./dev.db\" npx next dev'",
    "serve": "next start",
    "lint": "next lint",
    "setup": "DATABASE_URL='file:./dev.db' npm run db:generate && DATABASE_URL='file:./dev.db' npm run db:push",
    "db:push": "DATABASE_URL='file:./dev.db' prisma db push",
    "db:generate": "DATABASE_URL='file:./dev.db' prisma generate",
    "db:studio": "DATABASE_URL='file:./dev.db' prisma studio",
    "db:seed": "DATABASE_URL='file:./dev.db' tsx prisma/seed.ts",
    "full-setup": "rm -rf node_modules && npm install && npm run setup && npm run db:seed && npm start"
  },
  "dependencies": {
    "next": "^13.5.6",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-icons": "^4.12.0",
    "@prisma/client": "^5.7.0",
    "axios": "^1.6.0",
    "tailwindcss": "^3.3.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "clsx": "^2.0.0",
    "lucide-react": "^0.294.0",
    "date-fns": "^2.30.0",
    "@headlessui/react": "^1.7.17",
    "next-auth": "^4.24.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.38",
    "@types/react-dom": "^18.2.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "eslint": "^8.54.0",
    "eslint-config-next": "^14.0.0",
    "prisma": "^5.7.0",
    "tsx": "^4.6.0"
  }
}
